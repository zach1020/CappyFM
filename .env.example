DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DATABASE_URL=sqlite://data/cappyfm.db?mode=rwc
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=change-me

# Spotify credentials are required for Spotify links. The Apple token is
# optional for public links but recommended for reliable Apple Music access.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Register this exact URI in the Spotify Developer Dashboard. `./run
# spotify-login` stores the resulting refresh token in ignored runtime data.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Optional alternative to the per-machine data/spotify-refresh-token file.
SPOTIFY_REFRESH_TOKEN=
APPLE_MUSIC_API_TOKEN=

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4-nano
OPENAI_TTS_MODEL=tts-1
MUSICBRAINZ_USER_AGENT=CappyFM/0.1 (your-contact-url)
CAPPY_AUDIO_PUBLIC_BASE_URL=http://bot:8080

RUST_LOG=info,lavalink_rs=warn,serenity=warn,songbird=warn
CAPPY_ENV=development
CAPPY_LOG_SEARCH_QUERIES=false
CAPPY_CONFIG=config/cappyfm.toml
