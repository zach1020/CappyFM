#!/usr/bin/env bash

set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

die() {
  echo "CappyFM: $*" >&2
  exit 1
}

ensure_docker() {
  command -v docker >/dev/null 2>&1 || die "Docker is not installed. Install Docker Desktop first."
  docker compose version >/dev/null 2>&1 || die "Docker Compose v2 is not available."

  if docker info >/dev/null 2>&1; then
    return
  fi

  if [[ "$(uname -s)" == "Darwin" ]] && command -v open >/dev/null 2>&1; then
    echo "CappyFM: starting Docker Desktop..."
    open -ga Docker || die "Docker Desktop could not be opened."
    for _ in {1..60}; do
      if docker info >/dev/null 2>&1; then
        echo "CappyFM: Docker is ready."
        return
      fi
      sleep 2
    done
    die "Docker Desktop did not become ready within two minutes."
  fi

  die "the Docker daemon is not running. Start it, then run ./run again."
}

ensure_environment() {
  if [[ ! -f .env ]]; then
    cp .env.example .env
    chmod 600 .env
    die "created .env from .env.example. Fill in your secrets, then run ./run again."
  fi

  if grep -Eq '^[[:space:]]*DISCORD_TOKEN=[[:space:]]*$' .env; then
    die "DISCORD_TOKEN is empty in .env."
  fi

  mkdir -p data plugins
}

spotify_status() {
  local missing=0
  if ! grep -Eq '^[[:space:]]*SPOTIFY_CLIENT_ID=[^[:space:]].*$' .env; then
    echo "CappyFM: Spotify client ID is missing from .env."
    missing=1
  fi
  if ! grep -Eq '^[[:space:]]*SPOTIFY_CLIENT_SECRET=[^[:space:]].*$' .env; then
    echo "CappyFM: Spotify client secret is missing from .env."
    missing=1
  fi
  if [[ ! -s data/spotify-refresh-token ]] && ! grep -Eq '^[[:space:]]*SPOTIFY_REFRESH_TOKEN=[^[:space:]].*$' .env; then
    echo "CappyFM: Spotify playlist authorization is missing. Run './run spotify-login'."
    missing=1
  fi
  if (( missing == 0 )); then
    echo "CappyFM: Spotify credentials and playlist authorization are configured."
  fi
  return "$missing"
}

apple_music_status() {
  if grep -Eq '^[[:space:]]*APPLE_MUSIC_API_TOKEN=[^[:space:]].*$' .env; then
    echo "CappyFM: Apple Music song, album, and playlist link support is configured."
    return 0
  fi
  echo "CappyFM: Apple Music link support is disabled. Add APPLE_MUSIC_API_TOKEN to .env."
  return 1
}

action="${1:-start}"

case "$action" in
  start)
    ensure_docker
    ensure_environment
    spotify_status || true
    apple_music_status || true
    echo "CappyFM: building and starting the bot and Lavalink..."
    docker compose up -d --build --force-recreate
    docker compose ps
    echo
    echo "CappyFM is running. Use './run logs' to watch it or './run stop' to shut it down."
    ;;
  restart)
    ensure_docker
    ensure_environment
    spotify_status || true
    apple_music_status || true
    echo "CappyFM: rebuilding and restarting..."
    docker compose up -d --build --force-recreate
    docker compose ps
    ;;
  build)
    ensure_docker
    ensure_environment
    echo "CappyFM: building the bot and Lavalink images..."
    docker compose build
    echo "CappyFM: build complete. Run './run start' when you are ready."
    ;;
  stop)
    ensure_docker
    docker compose down
    echo "CappyFM is stopped. Persistent data remains in ./data."
    ;;
  logs)
    ensure_docker
    docker compose logs --tail=150 -f bot lavalink
    ;;
  status)
    ensure_docker
    docker compose ps
    ;;
  spotify-login)
    ensure_docker
    ensure_environment
    echo "CappyFM: building the one-time Spotify authorization helper..."
    echo "CappyFM: make sure http://127.0.0.1:8888/callback is listed in your Spotify app's redirect URIs."
    docker compose build bot
    docker compose run --rm --no-deps \
      -p 127.0.0.1:8888:8888 \
      -e SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback \
      -e SPOTIFY_REFRESH_TOKEN_FILE=/app/data/spotify-refresh-token \
      bot cappy-bot --spotify-login
    echo "CappyFM: restarting the bot with Spotify playlist access..."
    docker compose up -d --build bot
    ;;
  spotify-status)
    ensure_environment
    spotify_status
    ;;
  apple-music-status|apple-status)
    ensure_environment
    apple_music_status
    ;;
  *)
    die "unknown command '$action'. Use: ./run [start|restart|build|stop|logs|status|spotify-login|spotify-status|apple-music-status]"
    ;;
esac
